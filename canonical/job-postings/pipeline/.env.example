# Copy to .env (which is gitignored) and fill in one provider's creds.
# llm_client.py reads LLM_PROVIDER and dispatches to LiteLLM accordingly.

# Pick one: anthropic | bedrock | openai | vertex
LLM_PROVIDER=anthropic

# Optional: override the default model for the chosen provider.
# Defaults: anthropic -> claude-sonnet-4-6
#           bedrock   -> bedrock/anthropic.claude-sonnet-4-6
#           openai    -> gpt-4.1
#           vertex    -> vertex_ai/claude-sonnet-4-6
# LLM_MODEL=

# --- Anthropic direct ---
# ANTHROPIC_API_KEY=

# --- AWS Bedrock (Anthropic models require model access enabled in the AWS console) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# --- OpenAI ---
# OPENAI_API_KEY=

# --- Google Vertex AI ---
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# VERTEX_AI_PROJECT=
# VERTEX_AI_LOCATION=us-east5
